{
  "name": "yap-sum",
  "version": "0.5.4",
  "description": "Firefox extension (desktop + Android) for one-click YouTube AI summaries via your own LLM API key.",
  "type": "module",
  "private": true,
  "license": "AGPL-3.0-only",
  "author": "nalg",
  "scripts": {
    "lint": "web-ext lint --source-dir src",
    "run:desktop": "web-ext run --source-dir src --start-url 'https://www.youtube.com/watch?v=eIho2S0ZahI'",
    "run:android": "node scripts/run-android.mjs",
    "emulator": "sh scripts/android-emulator.sh up",
    "emulator:down": "sh scripts/android-emulator.sh down",
    "build": "web-ext build --source-dir src --artifacts-dir dist --overwrite-dest",
    "test": "node test/run-all.mjs",
    "test:fast": "node test/run-all.mjs --fast",
    "test:placement": "node test/smoke-placement.mjs",
    "test:shorts": "node test/smoke-shorts.mjs",
    "test:options": "node test/smoke-options.mjs",
    "test:full": "node test/smoke-full.mjs",
    "test:extract": "node test/webext-validate.mjs",
    "test:android": "node test/webext-validate.mjs --target firefox-android"
  },
  "devDependencies": {
    "web-ext": "^8.0.0"
  }
}
